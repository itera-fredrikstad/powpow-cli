{
	"name": "powpow-cli",
	"version": "0.3.0",
	"description": "Pro-code development tool for Power Pages with TypeScript transpilation and local development server features.",
	"type": "module",
	"license": "ISC",
	"author": "Philip Meidell <philip.meidell@itera.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/itera-fredrikstad/powpow-cli.git"
	},
	"bugs": {
		"url": "https://github.com/itera-fredrikstad/powpow-cli/issues"
	},
	"homepage": "https://github.com/itera-fredrikstad/powpow-cli#readme",
	"keywords": [
		"power-pages",
		"power-platform",
		"dataverse",
		"build-tool",
		"cli"
	],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"powpow": "dist/cli.js"
	},
	"files": [
		"dist",
		"types",
		"tsconfig.base.json",
		"powpow.config.schema.json"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"prepack": "tsc",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"format": "biome format --write",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@inquirer/prompts": "^7.0.0",
		"js-yaml": "^4.1.1",
		"rolldown": "1.0.0-rc.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.17.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	},
	"peerDependencies": {
		"typescript": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
